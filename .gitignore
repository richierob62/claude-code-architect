.DS_Store

# Claude Code local state — committed: settings.json. Ignored: per-user, runtime, and
# the commands/ dir (symlinks to ~/.claude/commands/ that only resolve on Rich's machine).
.claude/settings.local.json
.claude/worktrees/
.claude/plans/
.claude/commands/

# Ralph runtime artifacts
.ralph/run.log

# Env
.env
.env.local
.env.*.local

# Personal / not for the public repo
test-guidelines.md
scratch-pad.md
session-notes.md

# Learner answer scripts — gitignored on main (each lesson asks the learner
# to CREATE these; shipping them would spoil the exercise). On THIS branch
# (rich-learning) the dir is un-ignored so the author's own scripts are tracked.
# Keep this negation branch-local; never merge it into main.
!lessons/scripts/

.claude/settings.local.json
.claude/worktrees/
.claude/plans/
.claude/commands/

# Ralph runtime artifacts
.ralph/run.log

# Env
.env
.env.local
.env.*.local

# Personal / not for the public repo
test-guidelines.md
scratch-pad.md
session-notes.md

# Learner answer scripts — each lesson asks the learner to CREATE these.
# Shipping them on main would spoil the exercise. The original author's own
# scripts live on the rich-learning branch (which un-ignores this dir).
lessons/scripts/
